// AST coverage: precedence, unary ops, relational ops, and control flow

main
    local
        integer a;
        integer b;
        float c;
    do
        a = 1 + 2 * 3;
        b = -(a - 4) + +5;
        c = (a * b) / 2.0;

        if (a < b) then
            write(a + b * 2);
        else
            write(c);
        ;

        while (a <= 20) do
            a = a + 1;
        end;

        return(a);
    end
