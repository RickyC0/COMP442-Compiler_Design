// AST coverage: class declarations, inheritance, and class function definitions

class Animal {
    public integer age;
    public speak() : void;
};

class Dog inherits Animal {
    public integer breed;
    public bark(integer times) : void;
};

Animal::speak() : void
    do
        write(age);
    end

Dog::bark(integer times) : void
    local
        integer i;
    do
        i = 0;
        while (i < times) do
            write(breed);
            i = i + 1;
        end;
    end

main
    local
        Dog d;
    do
        d.age = 5;
        d.breed = 2;
        d.speak();
        d.bark(3);
    end
