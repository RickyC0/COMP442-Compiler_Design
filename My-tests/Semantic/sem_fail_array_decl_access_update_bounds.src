updateArray(integer arr[], integer size) : void
    local
        integer i;
    do
        i = 0;
        while (i < size) do
            arr[i] = arr[i] + 1;
            i = i + 1;
        end;
    end

main
    local
        integer data[4];
    do
        data[0] = 1;
        data[1] = 2;
        data[2] = 3;
        data[3] = 4;

        data[-1] = 99;
        updateArray(data, 6);
        updateArray(data, -1);
    end