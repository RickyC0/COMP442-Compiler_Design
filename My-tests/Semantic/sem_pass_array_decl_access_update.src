updateArray(integer arr[], integer size) : void
    local
        integer i;
    do
        i = 0;
        while (i < size) do
            arr[i] = arr[i] + 1;
            i = i + 1;
        end;
    end

main
    local
        integer data[4];
    do
        data[0] = 10;
        data[1] = 20;
        data[2] = 30;
        data[3] = 40;

        updateArray(data, 4);

        write(data[0]);
        write(data[1]);
        write(data[2]);
        write(data[3]);
    end