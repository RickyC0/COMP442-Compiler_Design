// TEST 6.1.12 / 9.3 [warning] overridden member function | EXPECT: WARNING

class Base {
    public foo(integer a) : void;
};

class Child inherits Base {
    public foo(integer a) : void;
};

Base::foo(integer a) : void
    do
        write(a);
    end

Child::foo(integer a) : void
    do
        write(a);
    end

main
  do
  end
