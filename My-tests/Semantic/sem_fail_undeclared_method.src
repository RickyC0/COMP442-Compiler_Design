// TEST 6.1.22 / 11.3 [error] undeclared member function (super lookup)   | EXPECT: ERROR

class Base {
    public ping() : void;
};

class Child inherits Base {
    public integer x;
};

Base::ping() : void
    do
        write(1);
    end

main
    local
        Child c;
    do
        c.ping();
        c.missing();
    end
