// TEST 6.1.16 / 11.1 [error] undeclared variable (local lookup)         | EXPECT: ERROR
// TEST 6.1.17 / 11.2 [error] member-function variable lookup in class    | EXPECT: ERROR
// TEST 6.1.18 / 11.2 [error] member-function variable lookup in inherited | EXPECT: ERROR

class Base {
    public integer inheritedValue;
};

class Child inherits Base {
    public integer ownValue;
    public probe() : void;
};

Child::probe() : void
    local
        integer localOnly;
    do
        localOnly = ownValue + inheritedValue;
        missing = localOnly + 1;
    end

main
    local
        Child c;
    do
        c.probe();
    end
