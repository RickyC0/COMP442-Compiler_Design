class Counter { // TEST 3.1.3 class declaration with public data + method declaration | EXPECT: PASS
    public integer value; // TEST 3.1.1 integer member declaration | EXPECT: PASS
    public inc(integer step) : void; // TEST 3.1.2 member function declaration | EXPECT: PASS
};

Counter::inc(integer step) : void // TEST 3.1.2 member function definition | EXPECT: PASS
    do
        value = value + step;
    end

next(integer x) : integer // TEST 3.1.2 free function definition | EXPECT: PASS
    do
        return(x + 1);
    end

main
    local
        Counter c;
        integer i;
    do
        c.value = 0;
        i = 0;

        while (i < 3) do // TEST 3.1.5 loop statement with do-end | EXPECT: PASS
            if (i == 1) then // TEST 3.1.5 conditional statement | EXPECT: PASS
                c.inc(2); // TEST 3.1.7 call as statement + 3.1.8 dot operator | EXPECT: PASS
            else
                c.inc(1); // TEST 3.1.7 call as statement + 3.1.8 dot operator | EXPECT: PASS
            ;
            i = next(i); // TEST 3.1.7 function call in expression | EXPECT: PASS
        end;

        write(c.value);
    end
