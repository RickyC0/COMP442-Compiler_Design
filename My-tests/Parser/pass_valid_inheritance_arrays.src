class Base {
    public integer id; // TEST 3.1.1 integer member declaration | EXPECT: PASS
};

class Derived inherits Base { // TEST 3.1.3 inheritance list (single parent) | EXPECT: PASS
    public integer values[4]; // TEST 3.1.1 integer array member declaration | EXPECT: PASS
    public fill(integer seed) : void; // TEST 3.1.2 member function declaration | EXPECT: PASS
};

Derived::fill(integer seed) : void // TEST 3.1.2 member function definition | EXPECT: PASS
    local
        integer i;
    do
        i = 0;
        while (i < 4) do // TEST 3.1.5 loop statement with do-end | EXPECT: PASS
            values[i] = seed + i; // TEST 3.1.9 array access (uni-dimensional index expr) | EXPECT: PASS
            i = i + 1;
        end;
    end

main
    local
        Derived d;
        integer idx;
    do
        d.fill(10); // TEST 3.1.7 function call as statement + 3.1.8 dot operator | EXPECT: PASS
        idx = 2;
        write(d.values[idx]); // TEST 3.1.8 dot operator with array member + 3.1.9 array index by expression | EXPECT: PASS
    end
